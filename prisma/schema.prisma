// 1. Настройки генератора и базы данных остаются без изменений
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. Создаем строгие перечисления для статусов
enum ParcelStatus {
  EXPECTED    // ожидается
  IN_TRANSIT  // в пути
  DELIVERED   // доставлено
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  phone            String?
  idDocument       String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt 
  
  parcels          Parcel[]
  partners         Partner[]
  carriers         Carrier[] 
}

model Carrier {
  id        String   @id @default(cuid())
  name      String   
  website   String?  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  // ИСПРАВЛЕНО: Связь parcels Parcel[] удалена, так как в Parcel мы используем просто строку (carrier String)
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  idDocument String?
  slotNumber Int?     
  isActive   Boolean  @default(false)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) 
  updatedAt  DateTime @updatedAt      
}

model Parcel {
  id           String    @id @default(cuid())
  trackCode    String    @unique
  name         String
  value        Float
  carrier      String    // Оставлено просто как строка
  expectedDate DateTime?
  purchaseDate DateTime?
  recipient    String
  comment      String?
  status       String    @default("ожидается") // Оставлено текстом для совместимости с фронтендом
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Alert {
  id         String         @id @default(cuid())
  type       String   
  message    String   
  severity   AlertSeverity  @default(INFO) 
  relatedHub String?  
  isResolved Boolean        @default(false)
  createdAt  DateTime       @default(now())
}