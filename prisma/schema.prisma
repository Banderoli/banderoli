generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Главный аккаунт пользователя (Заменяет OwnerProfile) ──
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String    // Хэш пароля для авторизации
  name       String    @default("Владелец")
  phone      String?
  telegramChatId String?
  documentId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  carriers         Carrier[]

  // Связи: у одного юзера может быть много партнеров и много посылок
  partners   Partner[]
  parcels    Parcel[]
}

// ── Дополнительные получатели (семья/друзья) ──
model Partner {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?
  documentId String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Связь с владельцем (К какому аккаунту принадлежит партнер)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Связь: один партнер -> много посылок
  parcels    Parcel[]
}

// ── Отправления (Грузы) ──
model Parcel {
  id               String    @id @default(uuid())
  trackCode        String    @unique
  name             String
  value            Float     // Стоимость в GEL
  weight           Float?    // Вес в КГ
  shop             String?   // Магазин (Amazon, ASOS и т.д.)
  carrier          String?   // Перевозчик (USA2GEORGIA, Camex)
  status           String    @default("Ожидается")
  
  // Даты
  purchaseDate     DateTime?
  expectedDelivery DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Связь с владельцем (В чьем кабинете находится посылка)
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Связь с получателем (если null, то получатель - сам Владелец)
  partnerId        String?
  partner          Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  recipientName    String?    // Денормализация для быстрого доступа
  
  // Дополнительно
  comment          String?
  
  // Вычисляемые риски
  hubWeatherRisk   Int       @default(0)
  flightDelayRisk  Int       @default(0)
  customsRiskScore Int       @default(0)

  // Поля для дашборда
  deliveryScheduleStatus String? @default("unknown")
  scheduleDeltaDays      Int?    @default(0)
}

model Alert {
  id         String   @id @default(uuid())
  type       String   // 'customs', 'weather', 'delay'
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  severity    String?   
  relatedHub  String?   

}

model Carrier {
  id        String   @id @default(uuid())
  name      String
  website   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}