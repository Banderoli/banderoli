generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // Раскомментируй, если используешь NeonDB/Supabase в режиме пуллера
}

// ── Главный аккаунт пользователя ─────────────────────────────
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String    // Хэш пароля
  name             String    @default("Владелец")
  role             String    @default("user")
  phone            String?
  telegramChatId   String?
  documentId       String?
  
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Связи
  shops            Shop[]
  carriers         Carrier[]
  partners         Partner[]
  parcels          Parcel[]
  alerts           Alert[]
}

// ── Дополнительные получатели (семья/друзья) ─────────────────
model Partner {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?
  documentId String?
  isActive   Boolean  @default(true)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now()) // ✅ Добавлено для консистентности

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcels    Parcel[]
}

// ── Магазины ──────────────────────────────────────────────────
model Shop {
  id         String   @id @default(cuid())
  name       String
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now()) // ✅ Добавлено для консистентности

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Перевозчики ───────────────────────────────────────────────
model Carrier {
  id         String   @id @default(uuid())
  name       String
  website    String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Отправления (Грузы) ───────────────────────────────────────
model Parcel {
  id                     String    @id @default(uuid())
  trackCode              String    @unique
  name                   String
  value                  Float     // Стоимость в GEL
  weight                 Float?    // Вес в КГ
  shop                   String?   // Магазин
  carrier                String?   // Перевозчик
  status                 String    @default("Ожидается")
  
  // Логистика (Для движка рисков)
  logisticsHub           String?   // Франкфурт, Нью-Йорк и т.д.
  estimatedFlight        String?   // Номер или дата рейса
  batchId                String?   // ID партии для отслеживания коллизий

  // Даты
  purchaseDate           DateTime?
  expectedDelivery       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  
  // Связи
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  partnerId              String?
  partner                Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  recipientName          String?   // Денормализация для быстрого доступа
  
  comment                String?
  
  // Вычисляемые риски
  hubWeatherRisk         Float?    @default(0)
  flightDelayRisk        Float?    @default(0)
  customsRiskScore       Float?    @default(0)
  collisionRisk          Float?    @default(0) // Вероятность встречи на таможне

  // Поля для дашборда
  deliveryScheduleStatus String?   @default("unknown")
  scheduleDeltaDays      Int?      @default(0)

  trackingEvents         TrackingEvent[]
}

// ── История трекинга ──────────────────────────────────────────
model TrackingEvent {
  id         String   @id @default(uuid())
  status     String
  location   String?
  message    String?
  timestamp  DateTime @default(now())

  parcelId   String
  parcel     Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

// ── Системные алерты (Погода, задержки) ───────────────────────
model Alert {
  id         String   @id @default(uuid())
  type       String   // 'customs', 'weather', 'delay'
  message    String
  isResolved Boolean  @default(false)
  severity   String?  
  relatedHub String?  

  createdAt  DateTime @default(now())

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ── Системные правила (Настройки лимитов и рисков) ────────────
model CustomsRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

model FlightRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model WeatherRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}