generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Настройки владельца аккаунта
model OwnerProfile {
  id         String   @id @default(uuid())
  name       String   @default("Владелец")
  phone      String?
  telegram   String?
  documentId String?
  updatedAt  DateTime @updatedAt
}

// Дополнительные получатели (семья/друзья)
model Partner {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?
  documentId String?
  isActive   Boolean  @default(true)
  parcels    Parcel[] // Связь: один партнер -> много посылок
  createdAt  DateTime @default(now())
}

// Отправления (Грузы)
model Parcel {
  id               String    @id @default(uuid())
  trackCode        String    @unique
  name             String
  value            Float     // Стоимость в GEL
  weight           Float?    // Вес в КГ
  shop             String?   // Магазин (Amazon, ASOS и т.д.)
  carrier          String?   // Перевозчик (USA2GEORGIA, Camex)
  status           String    @default("Ожидается")
  
  // Даты
  purchaseDate     DateTime?
  expectedDelivery DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Связь с получателем (если null, то получатель - Владелец)
  partnerId        String?
  partner          Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  recipientName    String    // Денормализация для быстрого доступа
  
  // Дополнительно
  comment          String?
  
  // Вычисляемые риски (сохраняем кэш для быстрой отдачи)
  hubWeatherRisk   Int       @default(0)
  flightDelayRisk  Int       @default(0)
  customsRiskScore Int       @default(0)

  // ── ВОССТАНОВЛЕННЫЕ ПОЛЯ ДЛЯ ДАШБОРДА ──
  deliveryScheduleStatus String? @default("unknown") // 'on_time', 'delayed', 'early', 'unknown'
  scheduleDeltaDays      Int?    @default(0)         // Дни отклонения графика
}

model Alert {
  id         String   @id @default(uuid())
  type       String   // 'customs', 'weather', 'delay'
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
}